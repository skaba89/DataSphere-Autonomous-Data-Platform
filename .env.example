# DataSphere API — Environment Variables
# Copy to .env and fill in values:  cp .env.example .env

# -----------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------
# Bearer token required on POST /generate and /generate/sync
# Leave empty to disable auth (development only)
DATASPHERE_API_KEY=

# Comma-separated list of allowed CORS origins
# Default (dev): http://localhost:3000,http://localhost:8000
# Production: set to your actual frontend domain(s)
DATASPHERE_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------
# Max POST/PUT/DELETE requests per minute per IP (0 = disabled)
DATASPHERE_RATE_LIMIT_RPM=60

# -----------------------------------------------------------------------
# Job persistence
# -----------------------------------------------------------------------
# Path to SQLite database file for job history
# Use an absolute path in a writable volume in containers
DATASPHERE_JOB_DB=/data/jobs.db

# -----------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------
# LOG_FORMAT: "json" (production) or "text" (development)
LOG_FORMAT=json
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------
# OpenTelemetry (optional — set to enable distributed tracing)
# -----------------------------------------------------------------------
DATASPHERE_OTLP_ENDPOINT=
# Example: DATASPHERE_OTLP_ENDPOINT=http://otel-collector:4317

# -----------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------
# Port for uvicorn
API_PORT=8000
